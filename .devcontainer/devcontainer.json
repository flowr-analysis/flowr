// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
//
// This container doubles as a "safebox": flowR executes analyzed R code without any
// sandboxing (see the interface docs), so running it here isolates that from your host.
{
	"name": "flowR",
	"build": { "dockerfile": "Dockerfile" },

	// flowR's server (`npm run flowr -- --server`) listens on 1042 by default.
	"forwardPorts": [1042],

	// Fetch LFS-backed test fixtures, install deps, and wire up the local git hooks.
	"postCreateCommand": "git lfs pull && npm ci && git config --local core.hooksPath .githooks/",

	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"REditorSupport.r",
				"code-inspect.vscode-flowr"
			],
			"settings": {
				"editor.codeActionsOnSave": { "source.fixAll.eslint": "explicit" }
			}
		}
	}
}
